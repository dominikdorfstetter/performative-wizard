; Engine configuration file.
; Performative Wizard — see DESIGN.md

config_version=5

[application]

config/name="Performative Wizard"
config/version="1.1.0-demo"
run/main_scene="res://scenes/hub/main_menu.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
boot_splash/bg_color=Color(0.0549, 0.0392, 0.0784, 1)
boot_splash/image="res://assets/boot_splash.png"
boot_splash/use_filter=false
config/icon="res://assets/icon.png"

[autoload]

Loc="*res://scripts/autoload/loc.gd"
Database="*res://scripts/autoload/database.gd"
SpriteBank="*res://scripts/autoload/sprite_bank.gd"
Audio="*res://scripts/autoload/audio.gd"
GameState="*res://scripts/autoload/game_state.gd"

[gui]

theme/custom_font="res://assets/fonts/jersey20.ttf"

[display]

window/size/viewport_width=1152
window/size/viewport_height=648
window/size/mode=2
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
